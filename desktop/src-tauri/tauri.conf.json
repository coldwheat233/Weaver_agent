{
  "productName": "Idea Weaver",
  "version": "0.1.0",
  "identifier": "com.idea-weaver.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "Idea Weaver · Input",
        "label": "input",
        "width": 560,
        "height": 520,
        "decorations": false,
        "transparent": false,
        "backgroundColor": "#FBFBFB",
        "alwaysOnTop": true,
        "visible": false,
        "center": true,
        "resizable": false,
        "skipTaskbar": true,
        "dragDropEnabled": false
      },
      {
        "title": "Idea Weaver · Dashboard",
        "label": "dashboard",
        "width": 620,
        "height": 580,
        "decorations": false,
        "transparent": false,
        "backgroundColor": "#FBFBFB",
        "alwaysOnTop": false,
        "visible": true,
        "center": true,
        "resizable": true,
        "minWidth": 500,
        "minHeight": 400
      }
    ],
    "security": {
      "csp": "default-src 'self' https: wss:; connect-src http://localhost:8765 https: wss:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "externalBin": ["binaries/weaver-backend"],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "displayLanguageSelector": false
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
